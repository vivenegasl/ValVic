# ValVic — Variables de entorno
# Copiar a .env y completar con valores reales
# cp .env.example .env && nano .env

# ── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Places (prospector) ─────────────────────────────
GOOGLE_PLACES_API_KEY=

# ── 360dialog WhatsApp API ─────────────────────────────────
DIALOG360_API_KEY=
DIALOG360_PHONE_ID=
DIALOG360_TEMPLATE_NAME=contacto_frio_valvic

# ── MySQL (Oracle HeatWave) ────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
