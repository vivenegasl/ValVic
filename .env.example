# ValVic — Variables de entorno
# Copiar a .env y completar con valores reales
# cp .env.example .env && nano .env

# ── Entorno ────────────────────────────────────────────────
# "production" activa cookies Secure (HTTPS) y logging de nivel WARNING
ENVIRONMENT=development

# ── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Places (prospector) ─────────────────────────────
GOOGLE_PLACES_API_KEY=

# ── WhatsApp Cloud API — Meta (Directo) ────────────────────
# Token de acceso permanente del System User (permisos: whatsapp_business_messaging)
META_ACCESS_TOKEN=
# Token de verificación definido por ti; debe coincidir con el del portal de Meta
META_VERIFY_TOKEN=
# App Secret de tu App de Meta (para validar firma X-Hub-Signature-256)
META_APP_SECRET=
# ID del número de teléfono vinculado a tu WABA
META_PHONE_NUMBER_ID=
# Nombre del template aprobado en Meta para contacto en frío
META_TEMPLATE_NAME=contacto_frio_valvic



# ── MySQL (Oracle HeatWave) ────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=valvic_app
MYSQL_PASSWORD=
MYSQL_DB=valvic_db

# ── WhatsApp del fundador ──────────────────────────────────
VALVIC_WHATSAPP=+56928417992

# ── JWT Panel CRM ─────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Oracle Object Storage — Backup MySQL ───────────────────────────
# Perfil y archivo de configuración OCI (~/.oci/config en la VM)
OCI_CONFIG_FILE=/opt/valvic/.oci/config
OCI_PROFILE=DEFAULT
# Namespace de tu tenancy (ver: Console → Object Storage → Buckets)
OCI_NAMESPACE=
# Nombre del bucket donde se subirán los backups
OCI_BUCKET_NAME=valvic-backups
# Prefijo/carpeta dentro del bucket
OCI_BACKUP_PREFIX=backups/valvic

# ── Configuración del Backup ────────────────────────────────────────
# Passphrase para encriptar el dump con openssl AES-256-CBC
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BACKUP_ENCRYPTION_KEY=
# Días de retención local de backups encriptados (default: 7)
BACKUP_RETENTION_DAYS=7
# Directorio local donde se almacenan temporalmente los backups
BACKUP_LOCAL_DIR=/tmp/valvic_backups
# Ruta del archivo de log
BACKUP_LOG_FILE=/var/log/valvic/backup.log
